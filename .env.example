# ============================================
# Environment Variables Template for Barflow
# ============================================
# Copy this file to .env.local for local development
# NEVER commit .env.local or .env.production with real values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini AI API Key
GEMINI_API_KEY=your-gemini-api-key

# Stripe Configuration
# Development  → use TEST keys (pk_test_... / sk_test_...)
# Production   → use LIVE keys (pk_live_... / sk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Obtain from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Register endpoint at: https://<your-domain>/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (replace with LIVE price IDs for production)
NEXT_PUBLIC_STRIPE_BAR_MONTHLY_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_BAR_YEARLY_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_CHAIN_PRICE_ID=price_xxx

# Dev account bypass (comma-separated emails that skip trial restrictions)
# Leave empty in production or set to your internal test accounts only
NEXT_PUBLIC_DEV_EMAILS=

# Resend (transactional emails)
# Get your API key at https://resend.com/api-keys
# Leave empty to disable email sending (emails will be skipped gracefully)
RESEND_API_KEY=re_your-resend-api-key

# App URL (use localhost for development)
NEXT_PUBLIC_APP_URL=http://localhost:3000
